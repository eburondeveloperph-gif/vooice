<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport"
        content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>Beatrice AI • Intelligent Assistant</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/@phosphor-icons/web"></script>
    <!-- Firebase SDKs -->
    <script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-auth-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-database-compat.js"></script>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Outfit', 'sans-serif'] },
                    colors: {
                        brand: {
                            purple: '#a855f7',
                            pink: '#ec4899',
                            dark: '#0a0a0a',
                            surface: 'rgba(255, 255, 255, 0.03)',
                            border: 'rgba(255, 255, 255, 0.05)',
                        }
                    },
                    animation: {
                        'spin-slow': 'spin 8s linear infinite',
                        'pulse-glow': 'pulseGlow 4s ease-in-out infinite alternate',
                        'fade-in-up': 'fadeInUp 0.8s ease-out forwards',
                    },
                    keyframes: {
                        pulseGlow: { '0%': { transform: 'scale(0.95)', boxShadow: '0 0 40px rgba(217,70,239,0.4)' }, '100%': { transform: 'scale(1.05)', boxShadow: '0 0 80px rgba(217,70,239,0.8), 0 0 120px rgba(126,34,206,0.6)' } },
                        fadeInUp: { '0%': { opacity: '0', transform: 'translateY(20px)' }, '100%': { opacity: '1', transform: 'translateY(0)' } }
                    }
                }
            }
        }
    </script>
    <style>
        :root {
            --app-bg: #050505;
        }

        body {
            background-color: var(--app-bg);
            background-image: radial-gradient(circle at 50% 0%, #3b0764 0%, transparent 50%);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
            color: white;
            font-family: 'Outfit', sans-serif;
            overflow: hidden;
        }

        .device-container {
            width: 100vw;
            height: 100dvh;
            background-color: #0a0a0a;
            position: relative;
            overflow: hidden;
        }

        .glass {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .glass-btn {
            transition: background 0.2s, transform 0.1s;
            cursor: pointer;
        }

        .glass-btn:active {
            transform: scale(0.96);
            background: rgba(255, 255, 255, 0.08);
        }

        .no-scrollbar::-webkit-scrollbar {
            display: none;
        }

        .no-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }

        .dynamic-island {
            width: 120px;
            height: 30px;
            background: #000;
            border-radius: 20px;
            position: absolute;
            top: 10px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 100;
        }

        .home-indicator {
            position: absolute;
            bottom: 8px;
            left: 50%;
            transform: translateX(-50%);
            width: 130px;
            height: 4px;
            background: rgba(255, 255, 255, 0.8);
            border-radius: 100px;
            z-index: 100;
        }

        .page-view {
            position: absolute;
            inset: 0;
            display: flex;
            flex-direction: column;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1), transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            transform: translateY(15px) scale(0.98);
            z-index: 10;
        }

        .page-view.active {
            opacity: 1;
            pointer-events: auto;
            transform: translateY(0) scale(1);
            z-index: 20;
        }

        .glowing-orb {
            border-radius: 50%;
            background: radial-gradient(circle at 30% 30%, #fdf4ff, #d946ef, #7e22ce);
            box-shadow: inset 0 0 20px rgba(255, 255, 255, 0.5), 0 0 50px rgba(217, 70, 239, 0.6), 0 0 100px rgba(126, 34, 206, 0.4);
        }

        .glowing-orb::before {
            content: '';
            position: absolute;
            inset: -10px;
            border-radius: 50%;
            background: conic-gradient(from 0deg, transparent, rgba(255, 255, 255, 0.3), transparent);
        }

        .media-placeholder {
            background: linear-gradient(135deg, #2563eb, #8b5cf6, #ec4899);
            position: relative;
        }

        .media-placeholder::after {
            content: '';
            position: absolute;
            inset: 0;
            mix-blend-mode: overlay;
            opacity: 0.3;
            background-image: url('data:image/svg+xml,%3Csvg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg"%3E%3Cfilter id="n"%3E%3CfeTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch"/%3E%3C/filter%3E%3Crect width="100%25" height="100%25" filter="url(%23n)"/%3E%3C/svg%3E');
        }

        /* Orb canvas */
        #orbCanvas {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            display: block;
        }

        .orb-container {
            position: relative;
            width: 180px;
            height: 180px;
        }

    </style>
</head>

<body>
    <main class="device-container" id="app">
        <div class="dynamic-island"></div>
        <div class="home-indicator"></div>
        <header
            class="absolute top-0 left-0 w-full flex justify-between items-center px-6 pt-3 text-[11px] font-medium z-[100] pointer-events-none">
            <span>9:41</span>
            <div class="flex items-center gap-1.5">
                <i class="ph-fill ph-cell-signal-full text-sm"></i>
                <i class="ph-fill ph-wifi-high text-sm"></i>
                <i class="ph-fill ph-battery-full text-[16px]"></i>
            </div>
        </header>

        <!-- SPLASH -->
        <section id="view-splash" class="page-view active bg-brand-dark justify-center items-center"
            aria-hidden="false">
            <div class="w-24 h-24 glowing-orb animate-pulse-glow mb-8">
                <div class="absolute inset-0 animate-spin-slow"></div>
            </div>
            <h1 class="text-4xl font-semibold tracking-wide">Beatrice</h1>
            <p class="text-sm text-fuchsia-300/80 mt-2 font-light">Intelligent Generation</p>
        </section>

        <!-- AUTH -->
        <section id="view-auth" class="page-view bg-brand-dark px-6" aria-hidden="true">
            <div
                class="absolute top-[-100px] right-[-100px] w-[300px] h-[300px] bg-brand-purple/15 blur-3xl rounded-full pointer-events-none">
            </div>
            <div class="flex-1 flex flex-col justify-center relative z-10 w-full">
                <div class="text-center mb-12">
                    <div class="w-16 h-16 glowing-orb mx-auto mb-6"></div>
                    <h1 class="text-[28px] font-semibold mb-2">Welcome Back</h1>
                    <p class="text-sm text-gray-400">Log in to continue with Beatrice</p>
                </div>
                <div class="space-y-4">
                    <button id="googleSignInBtn"
                        class="w-full glass glass-btn rounded-full py-3.5 px-4 flex items-center justify-center gap-3">
                        <i class="ph-fill ph-google-logo text-lg text-white"></i>
                        <span class="font-medium text-[15px]">Continue with Google</span>
                    </button>
                    <button
                        class="w-full glass glass-btn rounded-full py-3.5 px-4 flex items-center justify-center gap-3 opacity-50">
                        <i class="ph-fill ph-apple-logo text-lg text-white"></i>
                        <span class="font-medium text-[15px]">Continue with Apple</span>
                    </button>
                    <div class="relative py-4">
                        <div class="absolute inset-0 flex items-center">
                            <div class="w-full border-t border-white/10"></div>
                        </div>
                        <div class="relative flex justify-center"><span
                                class="px-3 bg-brand-dark text-xs text-gray-500 uppercase tracking-wide">Or</span></div>
                    </div>
                    <button
                        class="w-full glass glass-btn rounded-full py-3.5 px-4 flex items-center justify-center gap-3 text-gray-300 opacity-50">
                        <i class="ph ph-envelope-simple text-lg"></i><span class="font-medium text-[15px]">Continue with
                            Email</span>
                    </button>
                </div>
            </div>
        </section>

        <!-- HOME -->
        <section id="view-home" class="page-view bg-brand-dark" aria-hidden="true">
            <div
                class="absolute top-0 left-0 w-[300px] h-[300px] bg-brand-purple/15 blur-3xl rounded-full pointer-events-none">
            </div>
            <div class="flex-1 px-6 pt-14 pb-28 overflow-y-auto no-scrollbar relative z-10 flex flex-col">
                <nav class="flex justify-between items-center mb-6">
                    <button class="w-10 h-10 rounded-full glass glass-btn flex items-center justify-center"
                        aria-label="Menu"><i class="ph ph-list text-lg text-gray-300"></i></button>
                    <div class="flex items-center gap-3">
                        <button
                            class="nav-trigger w-10 h-10 rounded-full glass glass-btn flex items-center justify-center"
                            data-target="view-settings" aria-label="Settings"><i
                                class="ph ph-gear text-lg text-gray-300"></i></button>
                        <button
                            class="w-10 h-10 rounded-full glass glass-btn flex items-center justify-center relative"><i
                                class="ph ph-bell text-lg text-gray-300"></i><span
                                class="absolute top-2.5 right-2.5 w-2 h-2 bg-fuchsia-500 rounded-full border border-[#171717]"></span></button>
                    </div>
                </nav>
                <div class="flex items-center gap-3 mb-6 nav-trigger cursor-pointer w-max" data-target="view-profile">
                    <img src="https://i.pravatar.cc/100?img=11" alt="User"
                        class="w-11 h-11 rounded-full border border-white/20 object-cover">
                    <div>
                        <p class="text-[12px] text-gray-400 leading-tight" id="greetingText">Good Morning</p>
                        <p class="text-[15px] font-medium leading-tight mt-0.5" id="displayNameText">Mike Wheeler</p>
                    </div>
                </div>
                <header class="mb-6">
                    <h1 class="text-[32px] leading-[1.1] font-semibold">Intelligent Voice<br><span
                            class="text-white/80">Assistance</span></h1>
                </header>
                <div class="grid grid-cols-2 gap-4 mb-8">
                    <button
                        class="nav-trigger col-span-1 row-span-2 rounded-[28px] p-4 flex flex-col justify-between relative overflow-hidden border border-white/10 text-left active:scale-[0.98]"
                        data-target="view-voice" style="height:220px;">
                        <div class="absolute inset-0 bg-gradient-to-b from-fuchsia-400 to-purple-700 opacity-40"></div>
                        <div
                            class="w-8 h-8 rounded-full bg-white/20 backdrop-blur-md flex items-center justify-center relative z-10">
                            <i class="ph-fill ph-microphone text-white text-sm"></i></div>
                        <p class="text-sm font-medium relative z-10 mt-auto">Voice Assistant</p>
                    </button>
                    <button
                        class="nav-trigger glass glass-btn rounded-[24px] p-4 flex flex-col justify-between h-[102px] text-left"
                        data-target="view-video">
                        <div class="w-7 h-7 rounded-full bg-white/10 flex items-center justify-center"><i
                                class="ph-fill ph-play text-gray-300 text-xs"></i></div>
                        <p class="text-[13px] font-medium text-gray-200">Video Generation</p>
                    </button>
                    <button
                        class="nav-trigger glass glass-btn rounded-[24px] p-4 flex flex-col justify-between h-[102px] text-left"
                        data-target="view-image">
                        <div class="w-7 h-7 rounded-full bg-white/10 flex items-center justify-center"><i
                                class="ph-fill ph-camera text-gray-300 text-xs"></i></div>
                        <p class="text-[13px] font-medium text-gray-200">Image Generation</p>
                    </button>
                </div>
                <section class="mt-auto">
                    <div class="flex justify-between items-center mb-4">
                        <h2 class="text-[13px] font-medium text-gray-300">Quick Prompts</h2>
                    </div>
                    <ul class="flex flex-col gap-3" id="quickPromptsList">
                        <li><button
                                class="nav-trigger w-full glass glass-btn rounded-full py-2.5 px-3 flex items-center gap-3 text-left"
                                data-target="view-text" data-prompt="Explain quantum computing simply...">
                                <div
                                    class="w-7 h-7 rounded-full bg-fuchsia-500 flex items-center justify-center shrink-0">
                                    <i class="ph-fill ph-chat-text text-white text-xs"></i></div>
                                <p class="text-[12px] text-gray-300 truncate">Explain quantum computing simply...</p>
                            </button></li>
                    </ul>
                </section>
            </div>
        </section>

        <!-- VOICE -->
        <section id="view-voice" class="page-view bg-brand-dark" aria-hidden="true">
            <div
                class="absolute top-20 left-10 w-[300px] h-[300px] bg-brand-purple/20 blur-[80px] rounded-full pointer-events-none">
            </div>
            <div class="flex-1 flex flex-col relative z-10 px-6 pt-14 pb-12">
                <nav class="flex justify-between items-center">
                    <button class="nav-back w-10 h-10 rounded-full glass glass-btn flex items-center justify-center"><i
                            class="ph ph-caret-left text-lg text-gray-300"></i></button>
                    <div class="flex items-center gap-2 glass px-4 py-2 rounded-full"><span
                            class="text-[13px] font-medium">Beatrice</span><span
                            class="text-[10px] text-fuchsia-300 bg-fuchsia-500/20 px-2 py-0.5 rounded-full">1.0
                            Beta</span></div>
                    <button class="w-10 h-10 rounded-full glass glass-btn flex items-center justify-center"><i
                            class="ph ph-clock-counter-clockwise text-lg text-gray-300"></i></button>
                </nav>
                <div class="flex-1 flex items-center justify-center">
                    <div class="orb-container" id="orbWrapper"><canvas id="orbCanvas" class="w-full h-full"></canvas>
                    </div>
                </div>
                <article class="mb-4">
                    <p class="text-center text-[15px] text-gray-400/80 font-light px-2" id="voiceTranscriptDisplay">Tap
                        the orb to speak...</p>
                </article>
                <div class="flex flex-col items-center gap-6">
                    <p class="text-[13px] text-gray-400" id="orbStatusText">Beatrice is listening...</p>
                    <div class="flex items-center justify-between w-full px-4">
                        <button class="w-12 h-12 rounded-full glass glass-btn flex items-center justify-center"><i
                                class="ph ph-speaker-high text-xl text-gray-300"></i></button>
                        <button id="voiceMainBtn"
                            class="w-20 h-20 rounded-full bg-gradient-to-b from-fuchsia-400 to-purple-600 shadow-[0_0_30px_rgba(168,85,247,0.5)] flex items-center justify-center border-2 border-white/10 relative active:scale-95">
                            <div class="absolute inset-0 rounded-full bg-white/20 animate-ping opacity-20"></div>
                            <i class="ph-fill ph-microphone text-3xl text-white"></i>
                        </button>
                        <button
                            class="nav-trigger w-12 h-12 rounded-full glass glass-btn flex items-center justify-center"
                            data-target="view-text"><i class="ph ph-keyboard text-xl text-gray-300"></i></button>
                    </div>
                </div>
            </div>
        </section>

        <!-- TEXT CHAT -->
        <section id="view-text" class="page-view bg-brand-dark" aria-hidden="true">
            <div class="flex-1 flex flex-col relative z-10 px-6 pt-14 pb-12 h-full">
                <nav class="flex justify-between items-center mb-6 shrink-0 border-b border-white/5 pb-4">
                    <button class="nav-back w-10 h-10 rounded-full glass glass-btn flex items-center justify-center"><i
                            class="ph ph-caret-left text-lg text-gray-300"></i></button>
                    <div class="flex flex-col items-center">
                        <h2 class="text-[15px] font-medium">Beatrice</h2><span
                            class="text-[10px] text-green-400 flex items-center gap-1"><span
                                class="w-1.5 h-1.5 bg-green-400 rounded-full"></span> Online</span>
                    </div>
                    <button class="w-10 h-10 rounded-full glass glass-btn flex items-center justify-center"><i
                            class="ph ph-magnifying-glass text-lg text-gray-300"></i></button>
                </nav>
                <div class="flex-1 overflow-y-auto no-scrollbar flex flex-col gap-5" id="chatMessagesContainer">
                    <!-- dynamic messages -->
                </div>
                <form class="mt-4 glass rounded-full flex items-center p-1.5 pl-5 relative z-20 shrink-0" id="chatForm">
                    <input type="text" placeholder="Message Beatrice..." id="chatInput"
                        class="bg-transparent border-none outline-none text-[14px] flex-1 text-gray-200 placeholder-gray-500">
                    <button type="submit"
                        class="w-9 h-9 rounded-full bg-fuchsia-500 flex items-center justify-center shrink-0"><i
                            class="ph-fill ph-arrow-up text-white text-sm"></i></button>
                </form>
            </div>
        </section>

        <!-- SETTINGS (System Prompt) -->
        <section id="view-settings" class="page-view bg-brand-dark" aria-hidden="true">
            <div class="flex-1 flex flex-col relative z-10 px-6 pt-14 pb-12 h-full">
                <nav class="flex justify-between items-center mb-6 shrink-0">
                    <button class="nav-back w-10 h-10 rounded-full glass glass-btn flex items-center justify-center"><i
                            class="ph ph-caret-left text-lg text-gray-300"></i></button>
                    <h2 class="text-[15px] font-medium">AI Settings</h2>
                    <div class="w-10"></div>
                </nav>
                <div class="flex-1 overflow-y-auto no-scrollbar">
                    <div class="glass rounded-2xl p-4 mb-4">
                        <label class="text-sm text-gray-300 mb-2 block">System Prompt</label>
                        <textarea id="systemPromptInput"
                            class="w-full bg-white/5 border border-white/10 rounded-xl p-3 text-sm text-white placeholder-gray-500 resize-none h-32 focus:outline-none focus:border-fuchsia-500">You are Beatrice, a helpful, thoughtful assistant.</textarea>
                        <div class="flex gap-2 mt-3">
                            <button id="saveSystemPromptBtn"
                                class="glass-btn bg-fuchsia-500 text-white px-4 py-2 rounded-full text-xs font-medium">Save</button>
                            <button id="resetSystemPromptBtn"
                                class="glass-btn bg-white/10 text-gray-300 px-4 py-2 rounded-full text-xs">Reset</button>
                        </div>
                        <p id="saveFeedback" class="text-green-400 text-xs mt-2 opacity-0 transition">✓ Saved</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- PROFILE -->
        <section id="view-profile" class="page-view bg-brand-dark" aria-hidden="true">
            <div
                class="absolute top-0 right-0 w-[300px] h-[300px] bg-brand-pink/15 blur-3xl rounded-full pointer-events-none">
            </div>
            <div class="flex-1 px-6 pt-14 pb-12 overflow-y-auto no-scrollbar relative z-10 flex flex-col">
                <nav class="flex justify-between items-center mb-6 shrink-0"><button
                        class="nav-back w-10 h-10 rounded-full glass glass-btn flex items-center justify-center"><i
                            class="ph ph-caret-left text-lg text-gray-300"></i></button>
                    <h2 class="text-[15px] font-medium">Profile</h2>
                    <div class="w-10 h-10"></div>
                </nav>
                <div class="flex flex-col items-center mb-8"><img src="https://i.pravatar.cc/150?img=11"
                        class="w-24 h-24 rounded-full border-4 border-[#171717] mb-4 object-cover">
                    <h3 class="text-lg font-medium" id="profileName">Mike Wheeler</h3>
                    <p class="text-sm text-fuchsia-400">Beatrice Pro Member</p>
                </div>
                <div class="space-y-3">
                    <button
                        class="nav-trigger w-full glass glass-btn rounded-2xl p-4 flex justify-between items-center text-left"
                        data-target="view-settings"><span class="flex items-center gap-3 text-sm font-medium"><i
                                class="ph ph-gear text-lg text-gray-300"></i> Settings & Preferences</span><i
                            class="ph ph-caret-right text-gray-500"></i></button>
                    <button
                        class="w-full glass glass-btn rounded-2xl p-4 flex justify-between items-center text-left"><span
                            class="flex items-center gap-3 text-sm font-medium"><i
                                class="ph ph-clock-counter-clockwise text-lg text-gray-300"></i> Generation
                            History</span><i class="ph ph-caret-right text-gray-500"></i></button>
                    <button
                        class="w-full glass glass-btn rounded-2xl p-4 flex justify-between items-center text-left"><span
                            class="flex items-center gap-3 text-sm font-medium"><i
                                class="ph ph-credit-card text-lg text-gray-300"></i> Billing</span><i
                            class="ph ph-caret-right text-gray-500"></i></button>
                </div>
                <button id="logoutBtn"
                    class="mt-auto w-full glass glass-btn rounded-2xl p-4 flex justify-center items-center gap-2 text-red-400"><i
                        class="ph ph-sign-out text-lg"></i><span class="text-sm font-medium">Log Out</span></button>
            </div>
        </section>

        <!-- IMAGE & VIDEO (static placeholder pages remain) -->
        <section id="view-image" class="page-view bg-brand-dark" aria-hidden="true">
            <div
                class="absolute top-0 right-0 w-[250px] h-[250px] bg-brand-purple/15 blur-[60px] rounded-full pointer-events-none">
            </div>
            <div class="flex-1 flex flex-col relative z-10 px-6 pt-14 pb-12 h-full">
                <nav class="flex justify-between items-center mb-6 shrink-0"><button
                        class="nav-back w-10 h-10 rounded-full glass glass-btn flex items-center justify-center"><i
                            class="ph ph-caret-left text-lg text-gray-300"></i></button>
                    <h2 class="text-[15px] font-medium">Image Generation</h2><button
                        class="w-10 h-10 rounded-full glass glass-btn flex items-center justify-center"><i
                            class="ph ph-dots-three text-xl text-gray-300"></i></button>
                </nav>
                <div class="flex-1 overflow-y-auto no-scrollbar flex flex-col gap-6">
                    <article class="self-end glass rounded-2xl p-4 max-w-[90%]">
                        <p class="text-[13px] text-gray-200">Abstract smooth gradient...</p>
                    </article>
                    <div class="glass rounded-[24px] p-2">
                        <div class="w-full h-44 rounded-[18px] media-placeholder"></div>
                    </div>
                </div>
                <form class="mt-4 glass rounded-full flex items-center p-1.5 pl-5"><input type="text"
                        placeholder="Ask Beatrice anything"
                        class="bg-transparent border-none outline-none text-[14px] flex-1 text-gray-200 placeholder-gray-500"><button
                        class="w-9 h-9 rounded-full bg-fuchsia-500 flex items-center justify-center"><i
                            class="ph-fill ph-microphone text-white text-sm"></i></button></form>
            </div>
        </section>
        <section id="view-video" class="page-view bg-brand-dark" aria-hidden="true">
            <div
                class="absolute bottom-0 left-0 w-[300px] h-[300px] bg-blue-500/10 blur-[60px] rounded-full pointer-events-none">
            </div>
            <div class="flex-1 flex flex-col relative z-10 px-6 pt-14 pb-12 h-full">
                <nav class="flex justify-between items-center mb-6 shrink-0"><button
                        class="nav-back w-10 h-10 rounded-full glass glass-btn flex items-center justify-center"><i
                            class="ph ph-caret-left text-lg text-gray-300"></i></button>
                    <h2 class="text-[15px] font-medium">Video Generation</h2><button
                        class="w-10 h-10 rounded-full glass glass-btn flex items-center justify-center"><i
                            class="ph ph-faders text-xl text-gray-300"></i></button>
                </nav>
                <div class="flex-1 overflow-y-auto no-scrollbar flex flex-col gap-6">
                    <article class="self-end glass rounded-2xl p-4 max-w-[90%]">
                        <p class="text-[13px] text-gray-200">Cinematic neon city flythrough...</p>
                    </article>
                    <div class="glass rounded-[24px] p-2">
                        <div class="w-full h-44 rounded-[18px] media-placeholder flex items-center justify-center">
                            <button
                                class="w-12 h-12 rounded-full bg-white/20 backdrop-blur-md flex items-center justify-center"><i
                                    class="ph-fill ph-play text-white text-lg"></i></button></div>
                    </div>
                </div>
                <form class="mt-4 glass rounded-full flex items-center p-1.5 pl-5"><input type="text"
                        placeholder="Describe your video..."
                        class="bg-transparent border-none outline-none text-[14px] flex-1 text-gray-200 placeholder-gray-500"><button
                        class="w-9 h-9 rounded-full bg-blue-500 flex items-center justify-center"><i
                            class="ph-fill ph-paper-plane-right text-white text-sm"></i></button></form>
            </div>
        </section>

        <!-- BOTTOM NAV -->
        <nav id="bottom-nav"
            class="absolute bottom-6 left-1/2 -translate-x-1/2 w-[88%] glass rounded-[24px] px-6 py-3 flex justify-between items-center z-50 opacity-0 pointer-events-none transition-all duration-300 translate-y-4">
            <button class="nav-trigger nav-tab text-white flex flex-col items-center" data-target="view-home"><i
                    class="ph-fill ph-house text-[22px]"></i></button>
            <button class="nav-trigger nav-tab text-gray-500 flex flex-col items-center" data-target="view-text"><i
                    class="ph ph-chat-teardrop-text text-[22px]"></i></button>
            <button
                class="nav-trigger nav-tab center-fab w-14 h-14 rounded-full bg-gradient-to-tr from-fuchsia-500 to-purple-600 flex items-center justify-center text-white shadow-[0_0_20px_rgba(217,70,239,0.4)] transform -translate-y-4 border-[4px] border-[#0a0a0a]"
                data-target="view-voice"><i class="ph-fill ph-microphone text-[22px]"></i></button>
            <button class="nav-trigger nav-tab text-gray-500 flex flex-col items-center" data-target="view-image"><i
                    class="ph ph-camera text-[22px]"></i></button>
            <button class="nav-trigger nav-tab text-gray-500 flex flex-col items-center" data-target="view-profile"><i
                    class="ph ph-user text-[22px]"></i></button>
        </nav>
    </main>

    <script>
        // Firebase init
        const firebaseConfig = {
            apiKey: "AIzaSyDjmcE7CiKrNpSnu20gFB2cG620HU36Zqg",
            authDomain: "gen-lang-client-0836251512.firebaseapp.com",
            databaseURL: "https://gen-lang-client-0836251512-default-rtdb.firebaseio.com",
            projectId: "gen-lang-client-0836251512",
            storageBucket: "gen-lang-client-0836251512.firebasestorage.app",
            messagingSenderId: "811711024905",
            appId: "1:811711024905:web:65c6d67b963f9fec1b8dd8",
        };
        firebase.initializeApp(firebaseConfig);
        const auth = firebase.auth();
        const db = firebase.database();

        const DEEPSEEK_KEY = 'sk-15eab83ce74d4dfab037753a5ffef27c';
        const API_URL = 'https://api.deepseek.com/chat/completions';
        const DEFAULT_SYSTEM_PROMPT = 'You are Beatrice, a helpful, thoughtful, and intelligent AI assistant. You reason deeply before answering. Be warm, articulate, and thorough.';

        // Global state
        let currentUser = null;
        let systemPrompt = DEFAULT_SYSTEM_PROMPT;
        let activeConversationId = null;
        let conversations = [];
        let isStreaming = false;
        let abortController = null;

        // Voice state
        let audioContext = null, analyser = null, micStream = null, recognition = null;
        let orbState = 'idle';
        let orbAnimId = null;
        let orbData = { freqData: null, amplitude: 0, time: 0 };

        // DOM elements
        const views = document.querySelectorAll('.page-view');
        const googleSignInBtn = document.getElementById('googleSignInBtn');
        const logoutBtn = document.getElementById('logoutBtn');
        const systemPromptInput = document.getElementById('systemPromptInput');
        const saveSystemPromptBtn = document.getElementById('saveSystemPromptBtn');
        const resetSystemPromptBtn = document.getElementById('resetSystemPromptBtn');
        const saveFeedback = document.getElementById('saveFeedback');
        const chatMessagesContainer = document.getElementById('chatMessagesContainer');
        const chatForm = document.getElementById('chatForm');
        const chatInput = document.getElementById('chatInput');
        const orbCanvas = document.getElementById('orbCanvas');
        const orbWrapper = document.getElementById('orbWrapper');
        const voiceMainBtn = document.getElementById('voiceMainBtn');
        const orbStatusText = document.getElementById('orbStatusText');
        const voiceTranscriptDisplay = document.getElementById('voiceTranscriptDisplay');
        const greetingText = document.getElementById('greetingText');
        const displayNameText = document.getElementById('displayNameText');
        const profileName = document.getElementById('profileName');
        const bottomNav = document.getElementById('bottom-nav');

        // Router
        let history = ['view-splash'];
        let currentViewId = 'view-splash';

        function navigateTo(targetId, clearHistory = false) {
            if (currentViewId === targetId) return;
            const outView = document.getElementById(currentViewId);
            const inView = document.getElementById(targetId);
            if (outView) { outView.classList.remove('active'); outView.setAttribute('aria-hidden', 'true'); }
            if (inView) { inView.classList.add('active'); inView.setAttribute('aria-hidden', 'false'); }
            if (clearHistory) history = [targetId];
            else history.push(targetId);
            currentViewId = targetId;
            updateBottomNavVisibility();
            if (targetId === 'view-text') loadConversationIntoChat();
            if (targetId === 'view-voice') initVoicePage();
            if (targetId === 'view-settings') systemPromptInput.value = systemPrompt;
        }

        function goBack() {
            if (history.length > 1) {
                history.pop();
                const prev = history[history.length - 1];
                navigateTo(prev, true);
            }
        }

        function updateBottomNavVisibility() {
            if (currentViewId === 'view-home') {
                bottomNav.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-4');
            } else {
                bottomNav.classList.add('opacity-0', 'pointer-events-none', 'translate-y-4');
            }
            // highlight tabs
            document.querySelectorAll('.nav-tab').forEach(btn => {
                const icon = btn.querySelector('i');
                const isCenter = btn.classList.contains('center-fab');
                if (btn.dataset.target === currentViewId) {
                    if (!isCenter) { btn.classList.add('text-white'); btn.classList.remove('text-gray-500'); }
                    if (icon && icon.className.includes('ph ')) icon.className = icon.className.replace('ph ', 'ph-fill ');
                } else {
                    if (!isCenter) { btn.classList.remove('text-white'); btn.classList.add('text-gray-500'); }
                    if (icon && icon.className.includes('ph-fill ') && !isCenter) icon.className = icon.className.replace('ph-fill ', 'ph ');
                }
            });
        }

        // Auth
        auth.onAuthStateChanged(user => {
            currentUser = user;
            if (user) {
                loadUserData();
                if (currentViewId === 'view-splash' || currentViewId === 'view-auth') navigateTo('view-home', true);
            } else {
                if (currentViewId !== 'view-auth' && currentViewId !== 'view-splash') navigateTo('view-auth', true);
            }
        });

        googleSignInBtn.addEventListener('click', () => {
            const provider = new firebase.auth.GoogleAuthProvider();
            auth.signInWithPopup(provider).catch(e => alert('Sign-in error: ' + e.message));
        });

        logoutBtn.addEventListener('click', () => auth.signOut());

        function loadUserData() {
            if (!currentUser) return;
            db.ref('users/' + currentUser.uid + '/systemPrompt').once('value').then(snap => {
                systemPrompt = snap.val() || DEFAULT_SYSTEM_PROMPT;
                systemPromptInput.value = systemPrompt;
            });
            db.ref('users/' + currentUser.uid + '/conversations').once('value').then(snap => {
                const data = snap.val();
                conversations = data ? Object.values(data).sort((a, b) => b.updatedAt - a.updatedAt) : [];
                if (conversations.length === 0) createNewConversation();
                else activeConversationId = conversations[0].id;
            });
            // update UI names
            const displayName = currentUser.displayName || 'User';
            displayNameText.textContent = displayName;
            profileName.textContent = displayName;
            const hour = new Date().getHours();
            greetingText.textContent = hour < 12 ? 'Good Morning' : hour < 18 ? 'Good Afternoon' : 'Good Evening';
        }

        function saveSystemPrompt() {
            const val = systemPromptInput.value.trim();
            if (!val || !currentUser) return;
            db.ref('users/' + currentUser.uid + '/systemPrompt').set(val);
            systemPrompt = val;
            saveFeedback.classList.add('opacity-100');
            setTimeout(() => saveFeedback.classList.remove('opacity-100'), 2000);
        }

        // Conversations
        function createNewConversation() {
            const id = 'conv_' + Date.now() + '_' + Math.random().toString(36).substr(2, 6);
            const conv = { id, title: 'New Conversation', messages: [], createdAt: Date.now(), updatedAt: Date.now() };
            conversations.unshift(conv);
            activeConversationId = id;
            saveConversations();
        }

        function saveConversations() {
            if (!currentUser) return;
            const obj = {};
            conversations.forEach(c => obj[c.id] = c);
            db.ref('users/' + currentUser.uid + '/conversations').set(obj);
        }

        function getActiveConversation() {
            return conversations.find(c => c.id === activeConversationId);
        }

        function loadConversationIntoChat() {
            const conv = getActiveConversation();
            chatMessagesContainer.innerHTML = '';
            if (!conv) return;
            conv.messages.forEach(msg => {
                if (msg.role === 'user') appendChatBubble('user', msg.content);
                else appendChatBubble('assistant', msg.content, msg.reasoning_content);
            });
        }

        function appendChatBubble(role, content, reasoning = '') {
            const div = document.createElement('div');
            div.className = role === 'user' ? 'self-end glass rounded-2xl rounded-tr-sm p-4 max-w-[85%]' : 'self-start glass rounded-2xl rounded-tl-sm p-4 max-w-[90%] border-l-2 border-l-fuchsia-500';
            if (reasoning) {
                div.innerHTML = `<p class="text-[11px] text-yellow-400/80 italic mb-2">🧠 ${escapeHtml(reasoning)}</p>`;
            }
            div.innerHTML += `<p class="text-[13px] leading-relaxed text-gray-200">${escapeHtml(content)}</p>`;
            chatMessagesContainer.appendChild(div);
            chatMessagesContainer.scrollTop = chatMessagesContainer.scrollHeight;
        }

        function escapeHtml(str) {
            const d = document.createElement('div');
            d.textContent = str;
            return d.innerHTML;
        }

        async function sendChatMessage() {
            const text = chatInput.value.trim();
            if (!text || isStreaming) return;
            let conv = getActiveConversation();
            if (!conv) { createNewConversation(); conv = getActiveConversation(); }
            conv.messages.push({ role: 'user', content: text, timestamp: Date.now() });
            conv.title = text.slice(0, 40) + (text.length > 40 ? '...' : '');
            conv.updatedAt = Date.now();
            appendChatBubble('user', text);
            chatInput.value = '';
            saveConversations();
            isStreaming = true;
            abortController = new AbortController();
            const placeholderDiv = document.createElement('div');
            placeholderDiv.className = 'self-start glass rounded-2xl rounded-tl-sm p-4 max-w-[90%] border-l-2 border-l-fuchsia-500';
            placeholderDiv.innerHTML = '<p class="text-[13px] text-gray-400">Thinking...</p>';
            chatMessagesContainer.appendChild(placeholderDiv);
            const apiMessages = [
                { role: 'system', content: systemPrompt },
                ...conv.messages.map(m => ({ role: m.role, content: m.content }))
            ];
            try {
                const resp = await fetch(API_URL, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + DEEPSEEK_KEY },
                    body: JSON.stringify({ messages: apiMessages, model: 'deepseek-v4-pro', thinking: { type: 'enabled' }, reasoning_effort: 'high', max_tokens: 2048, stream: true, temperature: 1, top_p: 1 }),
                    signal: abortController.signal
                });
                const reader = resp.body.getReader();
                const decoder = new TextDecoder();
                let fullContent = '', fullReasoning = '';
                while (true) {
                    const { done, value } = await reader.read();
                    if (done) break;
                    const chunk = decoder.decode(value);
                    const lines = chunk.split('\n');
                    for (let line of lines) {
                        if (!line.startsWith('data: ')) continue;
                        const str = line.slice(6);
                        if (str === '[DONE]') continue;
                        try {
                            const json = JSON.parse(str);
                            const delta = json.choices?.[0]?.delta;
                            if (delta?.reasoning_content) fullReasoning += delta.reasoning_content;
                            if (delta?.content) fullContent += delta.content;
                            placeholderDiv.innerHTML = (fullReasoning ? `<p class="text-[11px] text-yellow-400/80 italic mb-2">🧠 ${escapeHtml(fullReasoning)}</p>` : '') + `<p class="text-[13px] text-gray-200">${escapeHtml(fullContent)}</p>`;
                            chatMessagesContainer.scrollTop = chatMessagesContainer.scrollHeight;
                        } catch (e) { }
                    }
                }
            } catch (e) {
                if (e.name === 'AbortError') fullContent += '\n[cancelled]';
                else fullContent = 'Error: ' + e.message;
                placeholderDiv.innerHTML = `<p class="text-[13px] text-gray-200">${escapeHtml(fullContent)}</p>`;
            }
            conv.messages.push({ role: 'assistant', content: fullContent, reasoning_content: fullReasoning, timestamp: Date.now() });
            saveConversations();
            placeholderDiv.remove();
            appendChatBubble('assistant', fullContent, fullReasoning);
            isStreaming = false;
            abortController = null;
        }

        chatForm.addEventListener('submit', e => { e.preventDefault(); sendChatMessage(); });

        // Voice orb
        function initVoicePage() {
            resizeOrbCanvas();
            startOrbIdleAnimation();
            orbState = 'idle';
            orbStatusText.textContent = 'Tap the orb to speak';
            voiceTranscriptDisplay.textContent = '';
        }

        function resizeOrbCanvas() {
            const rect = orbWrapper.getBoundingClientRect();
            const dpr = window.devicePixelRatio || 1;
            orbCanvas.width = rect.width * dpr;
            orbCanvas.height = rect.height * dpr;
            orbCanvas.style.width = rect.width + 'px';
            orbCanvas.style.height = rect.height + 'px';
        }

        voiceMainBtn.addEventListener('click', () => {
            if (orbState === 'idle') startListening();
            else if (orbState === 'listening') stopListeningAndProcess();
            else if (orbState === 'speaking') stopSpeaking();
        });

        async function startListening() {
            try {
                micStream = await navigator.mediaDevices.getUserMedia({ audio: true });
                audioContext = new (window.AudioContext || window.webkitAudioContext)();
                const source = audioContext.createMediaStreamSource(micStream);
                analyser = audioContext.createAnalyser();
                analyser.fftSize = 256;
                source.connect(analyser);
                orbState = 'listening';
                orbStatusText.textContent = 'Listening...';
                voiceTranscriptDisplay.textContent = '';
                startOrbVisualization();
                setupSpeechRecognition();
                if (recognition) recognition.start();
            } catch (e) {
                orbStatusText.textContent = 'Microphone denied';
            }
        }

        function setupSpeechRecognition() {
            const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
            if (!SpeechRecognition) return;
            recognition = new SpeechRecognition();
            recognition.continuous = true;
            recognition.interimResults = true;
            let finalTranscript = '';
            recognition.onresult = (event) => {
                let interim = '';
                for (let i = event.resultIndex; i < event.results.length; i++) {
                    if (event.results[i].isFinal) finalTranscript += event.results[i][0].transcript + ' ';
                    else interim += event.results[i][0].transcript;
                }
                voiceTranscriptDisplay.textContent = finalTranscript + interim;
            };
            recognition.onerror = (e) => { if (e.error !== 'no-speech') orbStatusText.textContent = 'Recognition error'; };
            recognition.onend = () => { if (orbState === 'listening') recognition.start(); };
        }

        async function stopListeningAndProcess() {
            const transcript = voiceTranscriptDisplay.textContent?.trim();
            if (recognition) { recognition.stop(); recognition = null; }
            if (micStream) { micStream.getTracks().forEach(t => t.stop()); micStream = null; }
            if (audioContext) { audioContext.close(); audioContext = null; analyser = null; }
            cancelAnimationFrame(orbAnimId);
            orbState = 'thinking';
            orbStatusText.textContent = 'Thinking...';
            startOrbThinkingAnimation();
            if (transcript) {
                try {
                    const resp = await fetch(API_URL, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + DEEPSEEK_KEY },
                        body: JSON.stringify({ messages: [{ role: 'system', content: systemPrompt }, { role: 'user', content: transcript }], model: 'deepseek-v4-pro', max_tokens: 1024, stream: false })
                    });
                    const data = await resp.json();
                    const reply = data.choices?.[0]?.message?.content || 'Sorry, I could not process that.';
                    voiceTranscriptDisplay.textContent = reply;
                    orbState = 'speaking';
                    orbStatusText.textContent = 'Speaking...';
                    startOrbSpeakingAnimation();
                    speakText(reply);
                } catch (e) {
                    voiceTranscriptDisplay.textContent = 'Error: ' + e.message;
                    orbState = 'idle';
                    orbStatusText.textContent = 'Tap the orb';
                    startOrbIdleAnimation();
                }
            } else {
                orbState = 'idle';
                orbStatusText.textContent = 'Tap the orb';
                startOrbIdleAnimation();
            }
        }

        function stopSpeaking() {
            window.speechSynthesis.cancel();
            orbState = 'idle';
            orbStatusText.textContent = 'Tap the orb';
            startOrbIdleAnimation();
        }

        function speakText(text) {
            const u = new SpeechSynthesisUtterance(text);
            u.onend = () => { orbState = 'idle'; orbStatusText.textContent = 'Tap the orb'; startOrbIdleAnimation(); };
            window.speechSynthesis.speak(u);
        }

        // Orb animation loops
        function drawOrb(ctx, cx, cy, r, state, data) {
            ctx.clearRect(0, 0, ctx.canvas.width, ctx.canvas.height);
            const dpr = window.devicePixelRatio || 1;
            const rad = r * dpr;
            // glow
            const glow = ctx.createRadialGradient(cx, cy, rad * 0.7, cx, cy, rad * 1.3);
            glow.addColorStop(0, 'rgba(167,139,250,0.4)'); glow.addColorStop(1, 'rgba(124,58,237,0)');
            ctx.fillStyle = glow; ctx.beginPath(); ctx.arc(cx, cy, rad * 1.3, 0, Math.PI * 2); ctx.fill();
            // main orb
            const grad = ctx.createRadialGradient(cx - rad * 0.2, cy - rad * 0.25, rad * 0.1, cx, cy, rad);
            grad.addColorStop(0, '#d4c4fc'); grad.addColorStop(0.4, '#a78bfa'); grad.addColorStop(0.8, '#5b21b6'); grad.addColorStop(1, '#1a0533');
            ctx.fillStyle = grad; ctx.beginPath(); ctx.arc(cx, cy, rad, 0, Math.PI * 2); ctx.fill();
            // rings
            for (let i = 0; i < 3; i++) {
                let ringR = rad * (1.1 + i * 0.12);
                if (state === 'listening' && data.freqData) ringR += (data.freqData[i * 20 + 10] / 255 - 0.5) * rad * 0.15;
                if (state === 'speaking') ringR += Math.sin(data.time * 3 + i) * rad * 0.08;
                ctx.strokeStyle = `rgba(167,139,250,${0.4 - i * 0.1})`; ctx.lineWidth = 1.5 * dpr;
                ctx.beginPath(); ctx.arc(cx, cy, ringR, 0, Math.PI * 2); ctx.stroke();
            }
            // particles
            const count = state === 'listening' ? 12 : 6;
            for (let i = 0; i < count; i++) {
                const angle = data.time * 0.3 + i * Math.PI * 2 / count;
                const dist = rad * 1.2 + Math.sin(data.time * 2 + i) * rad * 0.2;
                const px = cx + Math.cos(angle) * dist, py = cy + Math.sin(angle) * dist;
                ctx.fillStyle = `rgba(192,132,252,0.6)`; ctx.beginPath(); ctx.arc(px, py, 2 * dpr, 0, 2 * Math.PI); ctx.fill();
            }
        }

        function startOrbIdleAnimation() {
            cancelAnimationFrame(orbAnimId);
            const ctx = orbCanvas.getContext('2d');
            const dpr = window.devicePixelRatio || 1;
            const size = orbCanvas.width / dpr;
            const cx = size / 2 * dpr, cy = size / 2 * dpr, r = size * 0.38;
            function animate(t) { orbData.time = t * 0.001; orbData.amplitude = 0.05; drawOrb(ctx, cx, cy, r, 'idle', orbData); orbAnimId = requestAnimationFrame(animate); }
            orbAnimId = requestAnimationFrame(animate);
        }

        function startOrbVisualization() {
            cancelAnimationFrame(orbAnimId);
            const ctx = orbCanvas.getContext('2d');
            const dpr = window.devicePixelRatio || 1;
            const size = orbCanvas.width / dpr;
            const cx = size / 2 * dpr, cy = size / 2 * dpr, r = size * 0.38;
            function animate(t) {
                orbData.time = t * 0.001;
                if (analyser) { const freq = new Uint8Array(analyser.frequencyBinCount); analyser.getByteFrequencyData(freq); orbData.freqData = freq; orbData.amplitude = freq.reduce((a, b) => a + b, 0) / freq.length / 255; }
                drawOrb(ctx, cx, cy, r, 'listening', orbData);
                orbAnimId = requestAnimationFrame(animate);
            }
            orbAnimId = requestAnimationFrame(animate);
        }

        function startOrbThinkingAnimation() {
            cancelAnimationFrame(orbAnimId);
            const ctx = orbCanvas.getContext('2d');
            const dpr = window.devicePixelRatio || 1;
            const size = orbCanvas.width / dpr;
            const cx = size / 2 * dpr, cy = size / 2 * dpr, r = size * 0.38;
            function animate(t) { orbData.time = t * 0.001; drawOrb(ctx, cx, cy, r, 'thinking', orbData); orbAnimId = requestAnimationFrame(animate); }
            orbAnimId = requestAnimationFrame(animate);
        }

        function startOrbSpeakingAnimation() {
            cancelAnimationFrame(orbAnimId);
            const ctx = orbCanvas.getContext('2d');
            const dpr = window.devicePixelRatio || 1;
            const size = orbCanvas.width / dpr;
            const cx = size / 2 * dpr, cy = size / 2 * dpr, r = size * 0.38;
            function animate(t) { orbData.time = t * 0.001; drawOrb(ctx, cx, cy, r, 'speaking', orbData); orbAnimId = requestAnimationFrame(animate); }
            orbAnimId = requestAnimationFrame(animate);
        }

        // Event listeners for navigation
        document.querySelectorAll('.nav-trigger').forEach(btn => {
            btn.addEventListener('click', e => {
                const target = e.currentTarget.dataset.target;
                if (target) {
                    const prompt = e.currentTarget.dataset.prompt;
                    if (prompt && target === 'view-text') {
                        chatInput.value = prompt;
                        navigateTo(target);
                        setTimeout(() => sendChatMessage(), 100);
                    } else {
                        navigateTo(target);
                    }
                }
            });
        });
        document.querySelectorAll('.nav-back').forEach(btn => btn.addEventListener('click', goBack));

        saveSystemPromptBtn.addEventListener('click', saveSystemPrompt);
        resetSystemPromptBtn.addEventListener('click', () => {
            systemPromptInput.value = DEFAULT_SYSTEM_PROMPT;
            saveSystemPrompt();
        });

        // Initial splash timeout
        setTimeout(() => {
            if (currentUser) navigateTo('view-home', true);
            else navigateTo('view-auth', true);
        }, 2500);

        window.addEventListener('resize', () => { if (currentViewId === 'view-voice') resizeOrbCanvas(); });
    </script>
</body>

</html>